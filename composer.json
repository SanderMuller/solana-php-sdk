{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "collectiq/solana-php-sdk",
    "description": "PHP SDK for Solana — keypairs, transactions, RPC client, and program bindings (SPL Token, SNS, System).",
    "keywords": [
        "blockchain",
        "php",
        "sdk",
        "sol",
        "solana",
        "spl-token",
        "sns",
        "web3"
    ],
    "homepage": "https://github.com/collectiq/solana-php-sdk",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sander Muller",
            "email": "sander@hihaho.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4",
        "ext-sodium": "*",
        "illuminate/collections": "^11.31 || ^12.0 || ^13.0",
        "illuminate/container": "^11.31 || ^12.0 || ^13.0",
        "illuminate/http": "^11.31 || ^12.0 || ^13.0",
        "illuminate/support": "^11.31 || ^12.0 || ^13.0",
        "paragonie/sodium_compat": "^2.1",
        "phrity/websocket": "^3.5",
        "stephenhill/base58": "^1.1"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.9",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.1",
        "rector/type-perfect": "^2.0",
        "roave/security-advisories": "dev-latest",
        "sandermuller/package-boost": "^0.14.0",
        "spaze/phpstan-disallowed-calls": "^4.10",
        "symplify/phpstan-extensions": "^12.0",
        "tomasvotruba/cognitive-complexity": "^1.1",
        "tomasvotruba/type-coverage": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Collectiq\\SolanaPhpSdk\\": "src/"
        },
        "files": [
            "src/Bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Collectiq\\SolanaPhpSdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@sync-ai"
        ],
        "sync-ai": "vendor/bin/testbench package-boost:sync",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "format": "vendor/bin/pint",
        "format-test": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process",
        "rector-dry-run": "vendor/bin/rector process --dry-run",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html .cache/phpunit/coverage",
        "fix": [
            "@composer format",
            "vendor/bin/swiss-knife finalize-classes src",
            "vendor/bin/swiss-knife privatize-constants src",
            "vendor/bin/swiss-knife namespace-to-psr-4 src --namespace-root \"Collectiq\\SolanaPhpSdk\\\"",
            "@composer rector"
        ],
        "qa": [
            "@rector",
            "@format",
            "@phpstan-simplified"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Collectiq\\SolanaPhpSdk\\ServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
