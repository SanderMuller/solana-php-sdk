{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "collectiq/solana-php-sdk",
    "version": "0.1.0",
    "description": "PHP SDK for Solana",
    "keywords": [
        "blockchain",
        "php",
        "sdk",
        "sol",
        "solana"
    ],
    "homepage": "https://github.com/collectiq/solana-php-sdk",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-sodium": "*",
        "illuminate/container": "^11.31",
        "illuminate/collections": "^11.31",
        "illuminate/http": "^11.31",
        "illuminate/support": "^11.31",
        "paragonie/sodium_compat": "^2.1",
        "stephenhill/base58": "^1.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.8",
        "laravel/pint": "^1.19",
        "mockery/mockery": "^1.4",
        "orchestra/testbench": "^9.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.1",
        "rector/type-perfect": "^2.0",
        "roave/security-advisories": "dev-latest",
        "spaze/phpstan-disallowed-calls": "^4.1",
        "symplify/phpstan-extensions": "^12.0.1",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "tomasvotruba/type-coverage": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Collectiq\\SolanaPhpSdk\\": "src"
        },
        "files": [
            "src/Bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Collectiq\\SolanaPhpSdk\\Tests\\": "tests"
        }
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "rector": "vendor/bin/rector process",
        "rector-dry-run": "vendor/bin/rector process --dry-run",
        "fix": [
            "@composer format",
            "vendor/bin/swiss-knife finalize-classes src",
            "vendor/bin/swiss-knife privatize-constants src",
            "vendor/bin/swiss-knife namespace-to-psr-4 src --namespace-root \"Collectiq\\SolanaPhpSdk\\\"",
            "@composer rector"
        ]
    },
    "config": {
        "platform": {
            "php": "8.4.1"
        },
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Collectiq\\SolanaPhpSdk\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
